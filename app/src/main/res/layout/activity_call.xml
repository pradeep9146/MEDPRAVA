<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_dark_background"
    tools:context=".ui.messenger.CallActivity">

    <!-- Video View (for video calls) -->
    <FrameLayout
        android:id="@+id/remoteVideoView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/md_theme_dark_background" />

    <!-- Call Information -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Caller Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="John Doe"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- Call Type Label -->
        <TextView
            android:id="@+id/callTypeLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Voice Call"
            android:textColor="@android:color/white"
            android:textSize="14sp" />

        <!-- Call Duration -->
        <TextView
            android:id="@+id/callDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="00:45"
            android:textColor="@android:color/white"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- Call Controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:gravity="center_horizontal"
        android:orientation="horizontal"
        android:padding="24dp">

        <!-- Mute Button -->
        <ImageButton
            android:id="@+id/muteButton"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_margin="8dp"
            android:background="@drawable/call_button_background"
            android:contentDescription="Mute"
            android:src="@android:drawable/ic_dialog_info" />

        <!-- Camera Button (only for video calls) -->
        <ImageButton
            android:id="@+id/cameraButton"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_margin="8dp"
            android:background="@drawable/call_button_background"
            android:contentDescription="Toggle Camera"
            android:src="@android:drawable/ic_menu_camera" />

        <!-- End Call Button -->
        <ImageButton
            android:id="@+id/endCallButton"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_margin="8dp"
            android:background="@drawable/call_button_end_background"
            android:contentDescription="End Call"
            android:src="@android:drawable/ic_menu_close_clear_cancel" />
    </LinearLayout>
</FrameLayout>
